{
  "editor.fontFamily": "'Moralerspace Xenon HWNF', 'Moralerspace Xenon HWJPDOC'",
  "editor.formatOnSave": true,
  "editor.fontLigatures": "'calt', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'ss09', 'liga'",
  "editor.minimap.enabled": false,
  "editor.wordWrap": "on",
  "editor.renderControlCharacters": true,
  "editor.rulers": [60],
  "workbench.iconTheme": "gruvbox-material-icon-theme",
  "workbench.startupEditor": "none",
  "files.autoSave": "afterDelay",
  "terminal.external.linuxExec": "gnome-terminal",
  "rust-analyzer.check.allTargets": false,
  "[rust]": {
    "editor.formatOnSave": true
  },
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.check.command": "clippy",
  "markdown-preview-enhanced.enableExtendedTableSyntax": true,
  "[markdown]": {
    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
  },
  "git.openRepositoryInParentFolders": "never",
  "firedbg.showWelcome": false,
  "shellformat.effectLanguages": [
    "shellscript",
    "dockerfile",
    "dotenv",
    "hosts",
    "jvmoptions",
    "ignore",
    "gitignore",
    "properties",
    "spring-boot-properties",
    "azcli",
    "bats"
  ],
  "shellcheck.ignorePatterns": {
    "**/*.zsh": false
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "hediet.vscode-drawio.resizeImages": null,
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  },
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "clangd.checkUpdates": true,
  "redhat.telemetry.enabled": true,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.shellIntegration.history": 0,
  "terminal.integrated.shellIntegration.showCommandGuide": false,
  "terminal.integrated.fontSize": 14,
  "scm.inputFontSize": 14,
  "chat.editor.fontSize": 14,
  "rust-analyzer.cargo.allTargets": false,
  "cSpell.userWords": [
    "ACPI",
    "bitflags",
    "CLOEXEC",
    "Deque",
    "ecode",
    "epoll",
    "EPOLLIN",
    "EPOLLONESHOT",
    "fcntl",
    "FXRSTOR",
    "FXSAVE",
    "Gdtr",
    "GETFL",
    "hexdump",
    "hpet",
    "Idtr",
    "INTGATE",
    "inthandler",
    "iretq",
    "lgdt",
    "lidt",
    "ljmp",
    "ljump",
    "Mcfg",
    "mmap",
    "NONBLOCK",
    "PDPT",
    "repr",
    "rflags",
    "SETFL",
    "sysv",
    "uefi",
    "Uninit",
    "virt",
    "VTABLE",
    "xhci"
  ],
  "lldb.suppressUpdateNotifications": true,
  "vscode-pokemon.pokemonSize": "large",
  "workbench.colorTheme": "gruvboxConcoctis dark soft",
  "makefile.configureOnOpen": false,
  "claudeCode.preferredLocation": "panel",
  "rust-analyzer.restartServerOnConfigChange": true,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "clang-format.language.c.style": "Google",
  "clang-format.executable": "/opt/homebrew/bin/clang-format"
}
