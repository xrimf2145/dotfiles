// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "left",
  },
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "terminal": {
    "font_size": 14.0,
  },
  "base_keymap": "VSCode",
  "minimap": {
    "show": "never",
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "buffer_font_fallbacks": ["Moralerspace Xenon HWJPDOC"],
  "buffer_font_family": "Moralerspace Xenon HWJPDOC",
  "wrap_guides": [60],
  "soft_wrap": "editor_width",
  "agent_servers": {
    "cursor": {
      "type": "registry",
    },
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light",
    "dark": "Gruvbox Dark Soft",
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "allTargets": false,
        },
        "check": {
          "command": "clippy",
          "extraArgs": ["--target", "x86_64-unknown-uefi"],
        },
      },
    },
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    // "edit_debounce_ms": 700,
    // "scroll_debounce_ms": 50,
  },
}
